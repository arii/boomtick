{
  "name": "@boomtick/mcp",
  "version": "0.1.0",
  "description": "Boomtick MCP Guide: PR Rescue + Merge Conflict Agent",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "boomtick-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && shx cp src/tools/ddgs_search.py dist/tools/",
    "watch": "tsc -w",
    "start": "node dist/index.js",
    "test": "vitest run",
    "run-evals": "node dist/evals/run-evals.js",
    "release:patch": "pnpm version patch",
    "release:minor": "pnpm version minor",
    "release:major": "pnpm version major"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.28.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "shx": "^0.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
