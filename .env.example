# --- Required ---
# GitHub Personal Access Token (PAT)
# Required scopes: repo, workflow, read:org
GITHUB_TOKEN=

# --- AI Model Keys (Optional — for AI review and assistance features) ---
# Google Gemini API Key
GEMINI_API_KEY=

# OpenAI API Key (for GPT-4o etc.)
OPENAI_API_KEY=

# Google Jules API Key (for internal technical dancer agents)
GOOGLE_JULES_API_KEY=

# --- Automatically set by install.sh or mcp_config.json ---
# Absolute path to the boomtick repository root
# BOOMTICK_REPO_PATH=
