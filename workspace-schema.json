{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "type": { "type": "string" },
    "description": { "type": "string" },
    "scripts": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "engines": {
      "type": "object",
      "properties": {
        "node": { "type": "string" },
        "pnpm": { "type": "string" },
        "python": { "type": "string" }
      }
    }
  },
  "required": ["name", "version"]
}
