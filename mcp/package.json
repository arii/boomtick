{
  "name": "@arii/boomtick-mcp",
  "version": "0.2.1",
  "description": "Boomtick MCP Guide: PR Rescue + Merge Conflict Agent",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "boomtick-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && shx cp src/tools/ddgs_search.py dist/tools/ && tsx scripts/sync-mcp-schemas.ts",
    "watch": "tsc -w",
    "start": "node dist/index.js",
    "test": "tsx scripts/sync-contracts.ts && vitest run",
    "run-evals": "node dist/evals/run-evals.js",
    "sync:mcp-schemas": "tsx scripts/sync-mcp-schemas.ts",
    "release:patch": "pnpm version patch",
    "release:minor": "pnpm version minor",
    "release:major": "pnpm version major"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "json-schema-to-zod": "^2.8.1",
    "tsx": "^4.22.4",
    "shx": "^0.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
