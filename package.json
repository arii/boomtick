{
  "name": "boomtick-root",
  "version": "0.2.1",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": "24.x",
    "pnpm": "10.28.2"
  },
  "scripts": {
    "type-check": "pnpm --filter @arii/boomtick-mcp run type-check",
    "lint": "pnpm --filter @arii/boomtick-mcp run lint",
    "test": "pnpm --filter @arii/boomtick-mcp run test",
    "verify:schemas": "node scripts/verify-schemas.mjs",
    "check:runtime-files": "node scripts/check-runtime-files.mjs",
    "doctor": "node scripts/check-runtime-files.mjs",
    "preinstall": "node scripts/check-runtime-files.mjs",
    "sync-python-deps": "python3 scripts/sync-python-deps.py",
    "impact:analysis": "npx tsx scripts/impact-analysis.ts",
    "impact:build-main": "npx tsx scripts/impact-build-main.ts",
    "impact:visual-diff": "npx tsx scripts/impact-visual-diff.ts",
    "impact:dom-diff": "npx tsx scripts/impact-dom-diff.ts",
    "impact:gemini-code-review": "npx tsx scripts/impact-gemini-code-review.ts",
    "impact:github-models-code-review": "npx tsx scripts/impact-github-models-code-review.ts",
    "impact:gemini-review": "npx tsx scripts/impact-gemini-review.ts",
    "impact:github-models-review": "npx tsx scripts/impact-github-models-review.ts"
  },
  "devDependencies": {
    "@langchain/google-genai": "^0.1.2",
    "@playwright/test": "^1.50.1",
    "@types/diff": "^7.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^26.1.1",
    "@types/pngjs": "^6.0.5",
    "@types/sharp": "^0.32.0",
    "diff": "^7.0.0",
    "jscpd": "^5.0.12",
    "jsdom": "^26.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.33.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  }
}
